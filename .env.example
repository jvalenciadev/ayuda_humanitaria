# =============================================
# DATABASE
# =============================================
POSTGRES_DB=ayuda_humanitaria
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5432

# Prisma Connection URL
DATABASE_URL="postgresql://admin:admin123@TU_HOST_DB:5432/ayuda_humanitaria"

# =============================================
# API (apps/api) — Express Backend
# =============================================
PORT=3001
NODE_ENV=development
JWT_SECRET="cambia_esto_por_un_secreto_seguro_en_produccion"

# CORS: En producción, pon la URL de Vercel (separadas por coma si son varias)
# Ejemplo: CORS_ORIGIN=https://tu-proyecto.vercel.app
CORS_ORIGIN=http://localhost:3000

# =============================================
# WEB (apps/web) — Next.js Frontend
# =============================================
# En producción: apunta a la URL pública de tu API (Railway, Render, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
