datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Rol {
  id       String    @id
  nombre   String
  usuarios Usuario[]

  @@map("roles")
}

model Usuario {
  id                   String            @id @default(uuid())
  nombre               String
  email                String            @unique
  password             String
  rolId                String
  rol                  Rol               @relation(fields: [rolId], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?
  logs                 Log[]
  verificaciones       Verificacion[]
  comunicados          Comunicado[]

  @@map("usuarios")
}

model Departamento {
  id             String             @id // e.g. "LP", "CB", "SC", "OR", "PT", "TJ", "CH", "BE", "PD"
  nombre         String
  ayudas         AyudaHumanitaria[]
  reportes       Reporte[]
  victimas       Victima[]

  @@map("departamentos")
}

model Comunicado {
  id           String    @id @default(uuid())
  titulo       String
  contenido    String
  fuente       String
  autorId      String
  autor        Usuario   @relation(fields: [autorId], references: [id])
  estado       String    @default("VERIFICADO") // "PENDIENTE" | "VERIFICADO" | "RECHAZADO"
  fechaHora    DateTime  @default(now())
  documentoUrl String?
  multimedia   Archivo[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@map("comunicados")
}

model AyudaHumanitaria {
  id             String       @id @default(uuid())
  tipologia      String // "MEDICAMENTOS" | "OXIGENO" | "ALIMENTOS" | "TRANSPORTE" | "REFUGIO" | "DONACIONES" | "RESCATE_ANIMAL" | "APOYO_PSICOLOGICO"
  descripcion    String
  urgencia       String // "BAJA" | "MEDIA" | "ALTA" | "CRITICA"
  solicitante    String
  contacto       String
  departamentoId String
  departamento   Departamento @relation(fields: [departamentoId], references: [id])
  direccion      String
  latitud        Float?
  longitud       Float?
  estado         String       @default("PENDIENTE") // "PENDIENTE" | "EN_PROCESO" | "ATENDIDO" | "RECHAZADO"
  seguimiento    String?
  evidencias     Archivo[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("ayudas_humanitarias")
}

model Reporte {
  id             String         @id @default(uuid())
  titulo         String
  descripcion    String
  fuenteSocial   String?
  departamentoId String
  departamento   Departamento   @relation(fields: [departamentoId], references: [id])
  multimedia     Archivo[]
  estado         String         @default("EN_REVISION") // "VERIFICADO" | "EN_REVISION" | "INFORMACION_FALSA"
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  verificaciones Verificacion[]

  @@map("reportes")
}

model Victima {
  id                 String       @id @default(uuid())
  nombre             String
  documentoIdentidad String?
  edad               Int?
  genero             String?
  afectacionTipo     String // "LESIONADO" | "DESAPARECIDO" | "FALLECIDO" | "DAMNIFICADO"
  detalles           String
  contactoFamiliar   String?
  departamentoId     String
  departamento       Departamento @relation(fields: [departamentoId], references: [id])
  localidad          String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  @@map("victimas")
}

model Archivo {
  id                 String            @id @default(uuid())
  nombre             String
  url                String
  tipo               String // "IMAGE" | "VIDEO" | "DOCUMENT"
  ayudaId            String?
  ayuda              AyudaHumanitaria? @relation(fields: [ayudaId], references: [id])
  comunicadoId       String?
  comunicado         Comunicado?       @relation(fields: [comunicadoId], references: [id])
  reporteId          String?
  reporte            Reporte?          @relation(fields: [reporteId], references: [id])
  createdAt          DateTime          @default(now())

  @@map("archivos")
}

model Verificacion {
  id                String           @id @default(uuid())
  usuarioId         String
  usuario           Usuario          @relation(fields: [usuarioId], references: [id])
  observacion       String
  estadoAnterior    String?
  estadoNuevo       String
  reporteId         String?
  reporte           Reporte?         @relation(fields: [reporteId], references: [id])
  createdAt         DateTime         @default(now())

  @@map("verificaciones")
}

model Log {
  id          String   @id @default(uuid())
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  accion      String
  tabla       String
  registroId  String?
  detalles    String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("logs")
}
